{
  "name": "generate",
  "version": "2.0.0",
  "scripts": {
    "build": "scala-cli --power package --js-mode fast . -o src/index.js -f",
    "build-prod": "scala-cli --power package --js-mode full . -o src/index.js -f",
    "start": "npm run build && wrangler dev",
    "deploy": "npm run build-prod && wrangler deploy",
    "update": "npm outdated; npm install -g npm-check-updates; ncu; ncu -u; npm install"
  },
  "devDependencies": {
    "wrangler": "^4.103.0"
  },
  "private": true
}
